# ---- Qwen Cloud ----
QWEN_API_KEY=your_qwen_cloud_api_key
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-max

# ---- WhatsApp Business Cloud API ----
WHATSAPP_TOKEN=your_meta_whatsapp_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_VERIFY_TOKEN=choose_any_random_string

# ---- Database (Alibaba Cloud RDS for Postgres) ----
DATABASE_URL=postgresql://user:password@host:5432/arogya

# ---- Redis (session memory) ----
REDIS_URL=redis://localhost:6379/0

# ---- Emergency / 108 integration (placeholder) ----
EMERGENCY_WEBHOOK_URL=https://example.com/emergency-dispatch
